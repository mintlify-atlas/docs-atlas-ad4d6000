    "LessonView - Lesson content renderer",
    "QuizSection - Interactive quiz component",
    "HomeworkPage - Homework specifications and grading",
    "ProgressPage - Analytics dashboard",
    "InstructorGuide - Teaching notes and guidance",
    "BootcampNavigation - Week-based sidebar navigation",
